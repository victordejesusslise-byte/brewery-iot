# ─── MOSQUITTO ──────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_WS_PORT=9001

# Credenciais do ESP32 (publisher)
MQTT_ESP32_USER=esp32
MQTT_ESP32_PASSWORD=troque_esta_senha

# Credenciais do Node-RED (subscriber)
MQTT_NODERED_USER=nodered
MQTT_NODERED_PASSWORD=troque_esta_senha

# Tópico MQTT — DS18B20
MQTT_TOPIC_TEMPERATURE=brewery/sensors/temperature

# ─── NODE-RED ───────────────────────────────────────────
NODERED_PORT=1880
NODERED_ADMIN_USER=admin
NODERED_ADMIN_PASSWORD=troque_esta_senha
NODERED_CREDENTIAL_SECRET=chave_secreta_flows

# ─── GOOGLE SHEETS ──────────────────────────────────────
SHEETS_SPREADSHEET_ID=id_da_sua_planilha_aqui
SHEETS_CREDENTIALS_PATH=/data/credentials/service-account.json
SHEETS_TAB_READINGS=sensor_readings
SHEETS_TAB_EVENTS=event_logs
SHEETS_TAB_HEALTH=health_logs

# ─── PIPELINE — QUEUE / RETRY ───────────────────────────
QUEUE_MAX_SIZE=500
RETRY_DELAY_MS=60000
RETRY_MAX_ATTEMPTS=5
BUFFER_CSV_PATH=/data/buffer.csv

# ─── SENSOR — DS18B20 ───────────────────────────────────
SENSOR_TEMP_MIN=-55
SENSOR_TEMP_MAX=125